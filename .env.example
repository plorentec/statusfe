# Server port
PORT=3000

# Session secret — change this in production!
SESSION_SECRET=change-me-to-a-random-string

# PostgreSQL database
# Set DB_HOST to use an external PostgreSQL server (default: creates one via docker-compose)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=statusfe
# DB_USER=postgres
# DB_PASSWORD=
# DB_SSL=false

# HTTPS (self-signed cert)
HTTPS=false
