<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= page.name %> - System Status</title>
<meta name="refresh-interval" content="<%= typeof refreshInterval !== 'undefined' ? refreshInterval : '0' %>">
<% if (page.custom_layout && page.custom_layout_css) { %>
<style><%= page.custom_layout_css %></style>
<% } else if (page.template === 'grid') { %>
<link rel="stylesheet" href="/css/template-grid.css">
<% } else if (page.template === 'dark') { %>
<link rel="stylesheet" href="/css/template-dark.css">
<% } else { %>
<link rel="stylesheet" href="/css/status.css">
<% } %>
<% if (page.custom_css) { %><style><%= page.custom_css %></style><% } %>
</head>
<body class="<%= page.custom_layout ? 'custom-layout' : (page.template === 'default' ? '' : 'template-' + page.template) %>">

<% if (page.custom_layout && page.custom_layout_html) { %>
<!-- ===== CUSTOM LAYOUT ===== -->
<%
  const componentsData = components.map(c => ({
    id: c.id,
    name: c.name,
    status: c.current_status || c.status,
    description: c.description || '',
    group_name: c.group_name || 'Other'
  }));
  const incidentsData = (incidents || []).map(i => ({
    id: i.id,
    name: i.name,
    status: i.status,
    message: i.message,
    impact: i.impact || 'minor',
    starts_at: i.starts_at
  }));
  let layoutHtml = page.custom_layout_html;
  layoutHtml = layoutHtml.replace(/\{\{components\}\}/g, JSON.stringify(componentsData));
  layoutHtml = layoutHtml.replace(/\{\{incidents\}\}/g, JSON.stringify(incidentsData));
  layoutHtml = layoutHtml.replace(/\{\{page_name\}\}/g, page.name);
  layoutHtml = layoutHtml.replace(/\{\{page_status\}\}/g, page.status);
  layoutHtml = layoutHtml.replace(/\{\{page_description\}\}/g, page.description || '');
  layoutHtml = layoutHtml.replace(/\{\{formatStatus\}\}/g, 'function(s){return{operational:"Operational",under_maintenance:"Under Maintenance",degraded_performance:"Degraded Performance",partial_outage:"Partial Outage",major_outage:"Major Outage",investigating:"Investigating",identified:"Identified",monitoring:"Monitoring",resolved:"Resolved"}[s]||s;}');
  layoutHtml = layoutHtml.replace(/\{\{pageSlug\}\}/g, page.slug);
  layoutHtml = layoutHtml.replace(/\{\{refreshInterval\}\}/g, refreshInterval || '0');
%>
<%- layoutHtml %>
<% } else if (page.template === 'default') { %>
<!-- ===== DEFAULT TEMPLATE ===== -->
<div class="page-header">
<div class="page-header-inner">
<%- include('partials/_logo'); %>
<% if (page.logo_url) { %><img src="<%= page.logo_url %>" alt="<%= page.name %>" class="logo"><% } %>
<div>
<h1><%= page.name %></h1>
<p><%= page.description || 'System Status' %></p>
</div>
</div>
</div>
<div class="page-body">
<div class="container">
<div class="overall-status status-<%= page.status %>">
<span class="pulse-dot dot-<%= page.status %>"></span>
<div>
<span class="overall-label">Overall Status</span>
<span class="overall-value"><%= formatStatus(page.status) %></span>
</div>
</div>
<% if (incidents && incidents.length > 0) { %>
<% const activeIncs = incidents.filter(i => i.status !== 'resolved'); %>
<% if (activeIncs.length > 0) { %>
<% const worstImpact = (() => { const order = {critical:4,major:3,minor:2,none:1}; let w='none'; activeIncs.forEach(i => { if ((order[i.impact]||0) > (order[w]||0)) w = i.impact; }); return w; })(); %>
<div class="incidents-panel impact-<%= worstImpact %>">
<div class="incidents-panel-header">
<span class="alert-icon"></span>
<span class="incidents-count"><%= activeIncs.length %> Active Incident<%= activeIncs.length > 1 ? 's' : '' %></span>
</div>
<% activeIncs.forEach(inc => { %>
<div class="incident-row impact-<%= inc.impact || 'minor' %>">
<div class="incident-row-left">
<span class="incident-dot impact-<%= inc.impact || 'minor' %>"></span>
<div>
<div class="incident-row-name"><%= inc.name %></div>
<div class="incident-row-msg"><%= inc.message.replace(/\n/g, '<br>') %></div>
</div>
</div>
<span class="incident-row-badge badge-<%= inc.status %>"><%= formatStatus(inc.status) %></span>
</div>
<% }) %>
</div>
<% } %>
<% } %>
<% const groups = {}; %>
<% components.forEach(c => {
  const g = c.group_name || 'Other';
  if (!groups[g]) groups[g] = [];
  groups[g].push({ name: c.name, status: c.current_status || c.status, description: c.description });
}); %>
<% for (const [name, comps] of Object.entries(groups)) { %>
<div class="component-group">
<h2><%= name %></h2>
<% comps.forEach(c => { %>
<div class="component-row status-<%= c.status %>">
<div class="component-row-left">
<span class="component-dot dot-<%= c.status %>"></span>
<div>
<div class="component-name"><%= c.name %></div>
<div class="component-desc"><%= c.description || '' %></div>
</div>
</div>
<span class="component-badge badge-<%= c.status %>"><%= formatStatus(c.status) %></span>
</div>
<% }) %>
</div>
<% } %>
</div>
</div>
</main>
<footer><p>Powered by StatusFe</p></footer>

<!-- ===== GRID TEMPLATE ===== -->
<% } else if (page.template === 'grid') { %>
<header>
<div class="container">
<div class="header-content">
<%- include('partials/_logo'); %>
<% if (page.logo_url) { %><img src="<%= page.logo_url %>" alt="<%= page.name %>" class="logo"><% } %>
<div>
<h1><%= page.name %></h1>
<p class="subtitle"><%= page.description || 'System Status' %></p>
</div>
</div>
</div>
</header>
<div class="page-body">
<div class="container">
<div class="overall-status status-<%= page.status %>">
<span class="pulse-dot dot-<%= page.status %>"></span>
<div>
<span class="overall-label">Overall Status</span>
<span class="overall-value"><%= formatStatus(page.status) %></span>
</div>
</div>
<% if (incidents && incidents.length > 0) { %>
<% const activeIncs = incidents.filter(i => i.status !== 'resolved'); %>
<% if (activeIncs.length > 0) { %>
<% const worstImpact = (() => { const order = {critical:4,major:3,minor:2,none:1}; let w='none'; activeIncs.forEach(i => { if ((order[i.impact]||0) > (order[w]||0)) w = i.impact; }); return w; })(); %>
<div class="incidents-panel impact-<%= worstImpact %>">
<div class="incidents-panel-header">
<span class="alert-icon"></span>
<span class="incidents-count"><%= activeIncs.length %> Active Incident<%= activeIncs.length > 1 ? 's' : '' %></span>
</div>
<% activeIncs.forEach(inc => { %>
<div class="incident-row impact-<%= inc.impact || 'minor' %>">
<div class="incident-row-left">
<span class="incident-dot impact-<%= inc.impact || 'minor' %>"></span>
<div>
<div class="incident-row-name"><%= inc.name %></div>
<div class="incident-row-msg"><%= inc.message.replace(/\n/g, '<br>') %></div>
</div>
</div>
<span class="incident-row-badge badge-<%= inc.status %>"><%= formatStatus(inc.status) %></span>
</div>
<% }) %>
</div>
<% } %>
<% } %>
<div class="grid-container">
<% const groups = {}; %>
<% components.forEach(c => {
  const g = c.group_name || 'Other';
  if (!groups[g]) groups[g] = [];
  groups[g].push({ name: c.name, status: c.current_status || c.status, description: c.description });
}); %>
<% for (const [groupName, comps] of Object.entries(groups)) { %>
<div class="grid-group">
<h2><%= groupName %></h2>
<div class="card-grid">
<% comps.forEach(c => { %>
<div class="status-card <%= c.status %>">
<div class="card-top">
<span class="card-name"><%= c.name %></span>
<span class="card-status <%= c.status %>"><%= formatStatus(c.status) %></span>
</div>
<p class="card-desc"><%= c.description || '' %></p>
</div>
<% }) %>
</div>
</div>
<% } %>
</div>
</div>
<footer><p>Powered by StatusFe</p></footer>

<!-- ===== DARK TEMPLATE ===== -->
<% } else { %>
<header>
<div class="container">
<div class="header-content">
<%- include('partials/_logo'); %>
<% if (page.logo_url) { %><img src="<%= page.logo_url %>" alt="<%= page.name %>" class="logo"><% } %>
<div>
<h1><%= page.name %></h1>
<p class="subtitle"><%= page.description || 'System Status' %></p>
</div>
</div>
</div>
</header>
<div class="page-body">
<div class="container">
<div class="overall-status status-<%= page.status %>">
<span class="pulse-dot dot-<%= page.status %>"></span>
<div>
<span class="overall-label">Overall Status</span>
<span class="overall-value"><%= formatStatus(page.status) %></span>
</div>
</div>
<% if (incidents && incidents.length > 0) { %>
<% const activeIncs = incidents.filter(i => i.status !== 'resolved'); %>
<% if (activeIncs.length > 0) { %>
<% const worstImpact = (() => { const order = {critical:4,major:3,minor:2,none:1}; let w='none'; activeIncs.forEach(i => { if ((order[i.impact]||0) > (order[w]||0)) w = i.impact; }); return w; })(); %>
<div class="incidents-panel impact-<%= worstImpact %>">
<div class="incidents-panel-header">
<span class="alert-icon"></span>
<span class="incidents-count"><%= activeIncs.length %> Active Incident<%= activeIncs.length > 1 ? 's' : '' %></span>
</div>
<% activeIncs.forEach(inc => { %>
<div class="incident-row impact-<%= inc.impact || 'minor' %>">
<div class="incident-row-left">
<span class="incident-dot impact-<%= inc.impact || 'minor' %>"></span>
<div>
<div class="incident-row-name"><%= inc.name %></div>
<div class="incident-row-msg"><%= inc.message.replace(/\n/g, '<br>') %></div>
</div>
</div>
<span class="incident-row-badge badge-<%= inc.status %>"><%= formatStatus(inc.status) %></span>
</div>
<% }) %>
</div>
<% } %>
<% } %>
<div class="dark-container">
<% const groups = {}; %>
<% components.forEach(c => {
  const g = c.group_name || 'Other';
  if (!groups[g]) groups[g] = [];
  groups[g].push({ name: c.name, status: c.current_status || c.status, description: c.description });
}); %>
<% for (const [groupName, comps] of Object.entries(groups)) { %>
<div class="dark-group">
<h2><%= groupName %></h2>
<% comps.forEach(c => { %>
<div class="dark-item">
<div class="dark-item-left">
<span class="dot dot-<%= c.status %>"></span>
<div>
<div class="dark-item-name"><%= c.name %></div>
<div class="dark-item-desc"><%= c.description || '' %></div>
</div>
</div>
<div class="dark-item-right">
<span class="dark-badge <%= c.status %>"><%= formatStatus(c.status) %></span>
</div>
</div>
<% }) %>
</div>
<% } %>
</div>
</div>
<footer><p>Powered by StatusFe</p></footer>
<% } %>

<script>
<% if (page.custom_layout) { %>
// Custom layout mode — data available for JS
window.STATUSFE_DATA = {
  page: { name: '<%= page.name %>', slug: '<%= page.slug %>', status: '<%= page.status %>', description: '<%= (page.description || '').replace(/'/g, "\\'") %>' },
  components: <%= JSON.stringify(componentsData).replace(/</g, '\\u003c') %>,
  incidents: <%= JSON.stringify(incidentsData).replace(/</g, '\\u003c') %>
};
<% } else { %>
setInterval(() => {
  fetch('/api/v1/status/<%= page.slug %>').then(r => r.json()).then(d => {
    const b = document.querySelector('.overall-status');
    if (b && d.page) {
      b.className = 'overall-status status-' + d.page.status;
      const dot = b.querySelector('.pulse-dot');
      if (dot) dot.className = 'pulse-dot dot-' + d.page.status;
      const val = b.querySelector('.overall-value');
      if (val) val.textContent = formatStatus(d.page.status);
    }
  }).catch(() => {});
}, 60000);
<% } %>
function formatStatus(s) { return {operational:'Operational',under_maintenance:'Under Maintenance',degraded_performance:'Degraded Performance',partial_outage:'Partial Outage',major_outage:'Major Outage',investigating:'Investigating',identified:'Identified',monitoring:'Monitoring',resolved:'Resolved'}[s] || s; }

// Auto-refresh page at configured interval
(function() {
  var meta = document.querySelector('meta[name="refresh-interval"]');
  var seconds = meta ? parseInt(meta.content) : 0;
  if (seconds > 0) {
    var remaining = seconds;
    var counterEl = document.createElement('div');
    counterEl.setAttribute('id', 'refresh-counter');
    counterEl.style.cssText = 'position:fixed;top:10px;right:10px;background:rgba(0,0,0,0.85);color:#10b981;padding:8px 14px;border-radius:8px;font-size:13px;font-family:monospace;z-index:99999;border:1px solid rgba(16,185,129,0.3);backdrop-filter:blur(4px);box-shadow:0 2px 12px rgba(0,0,0,0.3);';
    document.body.appendChild(counterEl);
    var tick = function() {
      counterEl.textContent = '⟳ ' + remaining + 's';
      remaining--;
      if (remaining < 0) {
        remaining = seconds;
        location.reload();
      }
    };
    tick();
    setInterval(tick, 1000);
  }
})();
</script>
<% if (page.custom_html && !page.custom_layout) { %><%= page.custom_html %><% } %>
</body>
</html>
