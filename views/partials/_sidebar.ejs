<div class="sidebar-theme-btn" onclick="toggleAdminTheme()" title="Toggle dark/light mode" style="cursor:pointer;text-align:center;padding:12px 0 4px;border-top:1px solid var(--border);margin-top:8px;">
<span id="adminThemeIcon">🌙</span>
</div>
</div>
</aside>
<script>
(function(){const s=localStorage.getItem('statusfe-theme');if(s==='dark'){document.body.classList.add('dark');const i=document.getElementById('adminThemeIcon');if(i)i.textContent='☀️';}})();
function toggleAdminTheme(){document.body.classList.toggle('dark');const i=document.getElementById('adminThemeIcon');if(document.body.classList.contains('dark')){localStorage.setItem('statusfe-theme','dark');if(i)i.textContent='☀️';}else{localStorage.setItem('statusfe-theme','light');if(i)i.textContent='🌙';}}
</script>
