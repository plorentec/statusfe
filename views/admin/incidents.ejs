<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> - StatusFe Admin</title>
<link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="admin-layout">
<%- include('../partials/_sidebar'); %>
<main class="admin-main">
<div class="admin-header"><h1><%= title %></h1>
<% if (message) { %><div class="flash flash-<%= messageType %>"><%= message %></div><% } %>
</div>

<div class="card-header-row">
<h2>All Incidents</h2>
<a href="/admin/incidents/new" class="btn btn-primary">+ New Incident</a>
</div>

<% if (incidents.length === 0) { %>
<div class="card"><p class="empty-state">No incidents recorded.</p></div>
<% } else { %>
<div class="table-container">
<table class="admin-table">
<thead><tr><th>Name</th><th>Component</th><th>Status</th><th>Impact</th><th>Visible</th><th>Started</th><th>Actions</th></tr></thead>
<tbody>
<% incidents.forEach(inc => { %>
<tr>
<td><strong><%= inc.name %></strong><br><small class="text-muted"><%= (inc.message || '').substring(0, 60) %><%= (inc.message || '').length > 60 ? '...' : '' %></small></td>
<td><code><%= inc.component_id ? inc.component_id.substring(0,8) + '...' : '-' %></code></td>
<td><span class="status-badge status-<%= inc.status %>"><%= inc.status %></span></td>
<td><%= inc.impact || 'none' %></td>
<td><%- inc.visible ? '<span class="yes">Yes</span>' : '<span class="no">No</span>' %></td>
<td><%= inc.starts_at %></td>
<td class="actions">
<a href="/admin/incidents/<%= inc.id %>/edit" class="btn btn-sm">Edit</a>
<form action="/admin/incidents/<%= inc.id %>?_method=DELETE" method="post" class="delete-form" onsubmit="return confirm('Delete this incident?')">
<button type="submit" class="btn btn-sm btn-danger">Delete</button>
</form>
</td>
</tr>
<% }) %>
</tbody>
</table>
</div>
<% } %>
</main>
</div>
<script src="/js/admin.js"></script>
</body>
</html>
