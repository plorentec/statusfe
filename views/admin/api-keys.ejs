<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> - StatusPage Admin</title>
<link rel="stylesheet" href="/css/admin.css">
<style>
.key-display {
  display: flex;
  align-items: center;
  gap: 8px;
  background: #f8fafc;
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 8px 12px;
}
.key-display code {
  flex: 1;
  word-break: break-all;
  font-size: 12px;
}
.key-display .btn {
  flex-shrink: 0;
}
.perm-tag {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 12px;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.03em;
}
.perm-read { background: #dbeafe; color: #1e40af; }
.perm-write { background: #d1fae5; color: #065f46; }
.perm-admin { background: #fef3c7; color: #92400e; }
.api-key-row { display: flex; justify-content: space-between; align-items: center; }
</style>
</head>
<body>
<div class="admin-layout">
<aside class="sidebar">
<div class="sidebar-header">
<h2>StatusPage</h2>
<span class="sidebar-subtitle">Admin Panel</span>
</div>
<nav class="sidebar-nav">
<a href="/admin"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>Dashboard</a>
<a href="/admin/pages"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>Pages</a>
<a href="/admin/components"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42 1.42M18.36 5.64l1.42 1.42"/></svg>Components</a>
<a href="/admin/incidents"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>Incidents</a>
<a href="/admin/maintenance"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>Maintenance</a>
<a href="/admin/api-keys" class="<%= title === 'API Keys' ? 'active' : '' %>"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>API Keys</a>
<a href="/admin/docs"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>API Docs</a>
<a href="/admin/users"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>Users</a>
</nav>
<div class="sidebar-footer">
<div class="user-info">
<span class="user-name"><%= user.name %></span>
<span class="user-role"><%= user.role %></span>
</div>
<form action="/auth/logout" method="post"><button type="submit" class="btn-logout">Logout</button></form>
</div>
</aside>
<main class="admin-main">
<div class="admin-header"><h1><%= title %></h1>
<% if (message) { %>
<div class="flash flash-<%= messageType %>"><%= message %></div>
<% if (typeof key_value !== 'undefined' && key_value) { %>
<div class="card" style="margin-top:16px;border-color:#10b981;background:#f0fdf4">
<h3>🔑 New API Key Created</h3>
<div style="font-size:13px;margin-bottom:8px">Permissions: <%- (key_perms || 'read, write') %></div>
<div class="key-display">
<code id="newApiKey"><%= key_value %></code>
<button class="btn btn-sm" onclick="navigator.clipboard.writeText(document.getElementById('newApiKey').textContent);showToast('Key copied!','success')">Copy</button>
</div>
<p style="margin-top:12px;color:#dc2626;font-weight:600;font-size:13px">⚠ This key will never be shown again. Save it now.</p>
</div>
<% } %>
<% } %>
</div>

<!-- Create key form -->
<div class="card">
<h3>Create New API Key</h3>
<form action="/admin/api-keys" method="post">
<div class="form-row">
<div class="form-group">
<label for="name">Name</label>
<input type="text" id="name" name="name" required placeholder="e.g. Production bot">
</div>
<div class="form-group">
<label>Permissions</label>
<div class="checkbox-list">
<label><input type="checkbox" name="permissions" value="read" checked> Read</label>
<label><input type="checkbox" name="permissions" value="write" checked> Write</label>
<label><input type="checkbox" name="permissions" value="admin"> Admin</label>
</div>
</div>
</div>
<div class="form-actions" style="margin-top:0;padding-top:0;border-top:none">
<button type="submit" class="btn btn-primary">Create Key</button>
</div>
</form>
</div>

<!-- Key list -->
<% if (keys && keys.length > 0) { %>
<div class="table-container">
<table class="admin-table">
<thead><tr><th>Name</th><th>Key</th><th>Permissions</th><th>Active</th><th>Created</th><th>Actions</th></tr></thead>
<tbody>
<% keys.forEach(k => { %>
<tr>
<td><strong><%= k.name %></strong></td>
<td>
<div class="key-display">
<code><%= k.key_prefix %><%- k.full_key ? '••••••••••••••••••••••••••••' + k.full_key.slice(-8) : '' %></code>
<% if (k.full_key) { %>
<button class="btn btn-sm" onclick="copyKey(this, '<%= k.full_key.replace(/'/g, "\\'") %>')">Copy</button>
<% } %>
</div>
</td>
<td>
<% var perms = k.permissions; if (typeof perms === 'string') { try { perms = JSON.parse(perms); } catch(e) { perms = []; } } %>
<% (perms || []).forEach(p => { %>
<span class="perm-tag perm-<%= p %>"><%= p %></span>
<% }) %>
</td>
<td><%= k.is_active ? '<span class="yes">Active</span>' : '<span class="no">Revoked</span>' %></td>
<td><%= k.created_at %></td>
<td class="actions">
<% if (k.is_active) { %>
<form action="/admin/api-keys/<%= k.id %>" method="post" class="delete-form" onsubmit="return confirm('Revoke this API key?')">
<input type="hidden" name="_method" value="DELETE">
<button type="submit" class="btn btn-sm btn-danger">Revoke</button>
</form>
<form action="/admin/api-keys/<%= k.id %>/permanent" method="post" class="delete-form" onsubmit="return confirm('Permanently delete this API key? This cannot be undone.')">
<input type="hidden" name="_method" value="DELETE">
<button type="submit" class="btn btn-sm" style="color:#dc2626;border-color:#fecaca;">Delete</button>
</form>
<% } else { %>
<form action="/admin/api-keys/<%= k.id %>/reactivate" method="post" onsubmit="return confirm('Reactivate this API key?')">
<button type="submit" class="btn btn-sm" style="color:#065f46;border-color:#a7f3d0;background:#f0fdf4;">Reactivate</button>
</form>
<% } %>
</td>
</tr>
<% }) %>
</tbody>
</table>
</div>
<% } else { %>
<div class="card"><p class="empty-state">No API keys yet. Create one above.</p></div>
<% } %>
</main>
</div>
<script src="/js/admin.js"></script>
</body>
</html>
