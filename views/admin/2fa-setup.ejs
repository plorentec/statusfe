<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>2FA Setup - StatusFe Admin</title>
<link rel="stylesheet" href="/css/admin.css">
<script>document.body.classList.add('dark');</script>
</head>
<body>
<div class="admin-layout">
<aside class="sidebar">
<div class="sidebar-header">
<h2 style="display:flex;align-items:center;gap:8px;">
<span style="display:inline-flex;align-items:center;gap:8px;font-weight:800;font-size:22px;letter-spacing:-0.5px;"><span style="display:inline-flex;align-items:center;justify-content:center;width:38px;height:38px;background:linear-gradient(135deg,#10b981,#059669);border-radius:8px;color:#fff;font-size:18px;font-weight:900;line-height:1;">S</span><span>Status<span style="color:#10b981;">Fe</span></span></span>
</h2>
<span class="sidebar-subtitle">Admin Panel <a href="/admin/customize" style="color:#10b981;text-decoration:none;margin-left:4px;font-size:13px;">Customize</a></span>
</div>
<nav class="sidebar-nav">
<a href="/admin" class="<%= title === 'Dashboard' ? 'active' : '' %>">Dashboard</a>
<a href="/admin/pages" class="<%= title === 'Pages' ? 'active' : '' %>">Pages</a>
<a href="/admin/components" class="<%= title === 'Components' ? 'active' : '' %>">Components</a>
<a href="/admin/groups" class="<%= title === 'Component Groups' ? 'active' : '' %>">Groups</a>
<a href="/admin/incidents" class="<%= title === 'Incidents' ? 'active' : '' %>">Incidents</a>
<a href="/admin/maintenance" class="<%= title === 'Maintenance' ? 'active' : '' %>">Maintenance</a>
<a href="/admin/notifications" class="<%= title === 'Notifications' ? 'active' : '' %>">Notifications</a>
<a href="/admin/analytics" class="<%= title === 'Analytics' ? 'active' : '' %>">Analytics</a>
<a href="/admin/api-keys" class="<%= title === 'API Keys' ? 'active' : '' %>">API Keys</a>
<a href="/admin/docs" class="<%= title === 'API Docs' ? 'active' : '' %>">API Docs</a>
<a href="/admin/users" class="<%= title === 'Users' ? 'active' : '' %>">Users</a>
<a href="/admin/2fa/setup" class="active">2FA</a>
<a href="/admin/audit" class="<%= title === 'Audit Log' ? 'active' : '' %>">Audit Log</a>
</nav>
<div class="sidebar-footer">
<div class="user-info">
<span class="user-name"><%= user.name %></span>
<span class="user-role"><%= user.role %></span>
</div>
<form action="/auth/logout" method="post">
<button type="submit" class="btn-logout">Logout</button>
</form>
</div>
</aside>
<main class="admin-main">
<div class="admin-header">
<h1>Two-Factor Authentication</h1>
<% if (message) { %>
<div class="flash flash-<%= messageType %>"><%= message %></div>
<% } %>
</div>

<div class="card">
<h3>Setup 2FA for your account</h3>
<% if (!totpEnabled) { %>
<p class="text-muted">Scan the QR code below with your authenticator app (Google Authenticator, Authy, etc.)</p>
<div style="text-align:center; margin: 20px 0;">
<img src="<%= qr %>" alt="QR Code" style="border: 2px solid var(--border); border-radius: 8px; padding: 10px; background: #fff;">
</div>
<p class="text-muted" style="text-align:center;">Or enter this code manually: <code style="background:var(--bg);padding:4px 8px;border-radius:4px;"><%= user.totp_secret %></code></p>
<form action="/admin/2fa/setup" method="post" style="max-width:300px; margin: 20px auto;">
<input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
<input type="hidden" name="action" value="enable">
<div class="form-group">
<label for="code">Enter 6-digit code</label>
<input type="text" id="code" name="code" required maxlength="6" pattern="[0-9]{6}" inputmode="numeric" placeholder="123456">
</div>
<button type="submit" class="btn btn-primary btn-full">Enable 2FA</button>
</form>
<% } else { %>
<div style="padding: 15px; background: rgba(16,185,129,0.1); border: 1px solid var(--success); border-radius: 8px;">
<p style="color: var(--success); font-weight: 600;">2FA is enabled for your account.</p>
<p class="text-muted">You will be asked for a verification code on each login.</p>
</div>
<form action="/admin/2fa/setup" method="post" style="max-width:300px; margin-top: 15px;">
<input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
<input type="hidden" name="action" value="disable">
<div class="form-group">
<label for="code">Enter 6-digit code to confirm</label>
<input type="text" id="code" name="code" required maxlength="6" pattern="[0-9]{6}" inputmode="numeric" placeholder="123456">
</div>
<button type="submit" class="btn btn-danger btn-full">Disable 2FA</button>
</form>
<% } %>
</div>

</main>
</div>
<%- include("../partials/_csrf"); %>
<script src="/js/admin.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  var token = document.getElementById('csrfToken').value;
  if (!token) return;
  var forms = document.querySelectorAll('form[method="post"]');
  for (var i = 0; i < forms.length; i++) {
    var hidden = forms[i].querySelector('input[name="_csrf"]');
    if (!hidden) {
      var input = document.createElement('input');
      input.type = 'hidden';
      input.name = '_csrf';
      input.value = token;
      forms[i].appendChild(input);
    }
  }
});
</script>
</body>
</html>
