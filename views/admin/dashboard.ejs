<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> - StatusFe Admin</title>
<link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="admin-layout">
<%- include('../partials/_sidebar'); %>
<main class="admin-main">
<div class="admin-header">
<h1><%= title %></h1>
<% if (message) { %>
<div class="flash flash-<%= messageType %>"><%= message %></div>
<% } %>
</div>

<div class="stats-grid">
<div class="stat-card">
<div class="stat-icon stat-pages">
<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
</div>
<div class="stat-info">
<div class="stat-value"><%= stats.pageCount %></div>
<div class="stat-label">Pages</div>
</div>
</div>
<div class="stat-card">
<div class="stat-icon stat-components">
<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
</div>
<div class="stat-info">
<div class="stat-value"><%= stats.componentCount %></div>
<div class="stat-label">Components</div>
</div>
</div>
<div class="stat-card">
<div class="stat-icon stat-operational">
<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
</div>
<div class="stat-info">
<div class="stat-value"><%= stats.operationalCount %></div>
<div class="stat-label">Operational</div>
</div>
</div>
<div class="stat-card">
<div class="stat-icon stat-incidents">
<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
</div>
<div class="stat-info">
<div class="stat-value"><%= stats.openIncidents %></div>
<div class="stat-label">Open Incidents</div>
</div>
</div>
<div class="stat-card">
<div class="stat-icon stat-total-incidents">
<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
</div>
<div class="stat-info">
<div class="stat-value"><%= stats.incidentCount %></div>
<div class="stat-label">Total Incidents</div>
</div>
</div>
<div class="stat-card">
<div class="stat-icon stat-users">
<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
</div>
<div class="stat-info">
<div class="stat-value"><%= stats.userCount %></div>
<div class="stat-label">Users</div>
</div>
</div>
<div class="stat-card">
<div class="stat-icon stat-info" style="background: #0ea5e9;">
<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
</div>
<div class="stat-info">
<div class="stat-value"><%= diskInfo.percentage %>%</div>
<div class="stat-label">Disk Usage</div>
</div>
</div>
</div>

<!-- Disk Usage -->
<div class="card">
<h3 style="font-size: 16px; font-weight: 600; margin-bottom: 16px; padding-bottom: 12px; border-bottom: 1px solid var(--border);">Disk Usage</h3>
<div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
<div style="flex:1;min-width:200px;">
<div style="display:flex;justify-content:space-between;font-size:14px;margin-bottom:6px;">
<span>Storage</span>
<span style="font-weight:600;"><%= diskInfo.dbSize ? (diskInfo.dbSize / (1024*1024)).toFixed(1) + ' MB (DB)' : diskInfo.percentage + '% used' %></span>
</div>
<div style="height:10px;background:var(--border);border-radius:5px;overflow:hidden;">
<div style="height:100%;width:<%= diskInfo.percentage || 0 %>%;background:<%= parseFloat(diskInfo.percentage) >= 90 ? '#ef4444' : parseFloat(diskInfo.percentage) >= 75 ? '#f59e0b' : '#10b981' %>;border-radius:5px;transition:width 0.5s;"></div>
</div>
<% if (diskInfo.total > 0) { %>
<div style="font-size:12px;color:var(--text-muted);margin-top:6px;"><%= (diskInfo.used / (1024*1024*1024)).toFixed(2) %> GB used of <%= (diskInfo.total / (1024*1024*1024)).toFixed(2) %> GB</div>
<% } %>
<% if (diskInfo.dbOnly) { %>
<div style="font-size:12px;color:var(--text-muted);margin-top:6px;">Database: <%= (diskInfo.dbSize / (1024)).toFixed(0) %> KB</div>
<% } %>
</div>
</div>
</div>

<div class="dashboard-grid">
<div class="dashboard-card">
<h3>Page Status Overview</h3>
<div class="page-status-list">
<% if (pageStatuses.length === 0) { %>
<p class="empty-state">No pages configured yet.</p>
<% } else { %>
<% pageStatuses.forEach(p => { %>
<div class="page-status-item">
<span class="page-status-name"><%= p.name %></span>
<span class="page-status-badge status-<%= p.status %>"><%= p.status %></span>
</div>
<% }) %>
<% } %>
</div>
</div>

<div class="dashboard-card">
<h3>Recent Incidents</h3>
<% if (recentIncidents.length === 0) { %>
<p class="empty-state">No incidents recorded.</p>
<% } else { %>
<div class="incident-list">
<% recentIncidents.forEach(inc => { %>
<div class="incident-item">
<div class="incident-info">
<div class="incident-name"><%= inc.name %></div>
<div class="incident-meta"><%= inc.starts_at %></div>
</div>
<span class="incident-status status-<%= inc.status %>"><%= inc.status %></span>
</div>
<% }) %>
</div>
<% } %>
</div>
</div>

</main>
</div>
<script src="/js/admin.js"></script>
</body>
</html>
