<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> - StatusFe Admin</title>
<link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="admin-layout">
<%- include('../partials/_sidebar'); %>
<main class="admin-main">
<div class="admin-header">
<h1><%= title %></h1>
<% if (message) { %>
<div class="flash flash-<%= messageType %>"><%= message %></div>
<% } %>
</div>

<div class="doc-tabs">
<button class="doc-tab-btn active" data-tab="internal">Internal Notifications</button>
<button class="doc-tab-btn" data-tab="email">Email (SMTP)</button>
</div>

<!-- Internal Notifications Tab -->
<div class="doc-tab-content active" id="tab-internal">
<div class="card-header-row">
<h2>Notification History</h2>
<% if (hasNotifications) { %>
<form action="/admin/notifications/read-all" method="post">
<button type="submit" class="btn btn-sm">Mark all as read</button>
</form>
<% } %>
</div>

<% if (!hasNotifications) { %>
<div class="card"><p class="text-muted">No notifications yet.</p></div>
<% } else { %>
<div class="table-container">
<table class="admin-table">
<thead>
<tr>
<th>Type</th>
<th>Title</th>
<th>Message</th>
<th>Date</th>
<th>Actions</th>
</tr>
</thead>
<tbody>
<% notifications.forEach(n => { %>
<tr class="<%= n.is_read ? '' : 'unread' %>">
<td><span class="notif-type notif-<%= n.type %>"><%= n.type %></span></td>
<td><strong><%= n.title %></strong></td>
<td><%= (n.message || '').substring(0, 100) %></td>
<td><%= n.created_at %></td>
<td class="actions">
<% if (!n.is_read) { %>
<form action="/admin/notifications/<%= n.id %>/read" method="post">
<button type="submit" class="btn btn-sm">Mark read</button>
</form>
<% } %>
<form action="/admin/notifications/<%= n.id %>?_method=DELETE" method="post" class="delete-form">
<button type="submit" class="btn btn-sm btn-danger">Delete</button>
</form>
</td>
</tr>
<% }) %>
</tbody>
</table>
</div>
<% } %>
</div>

<!-- Email Settings Tab -->
<div class="doc-tab-content" id="tab-email">
<div class="card">
<h2 style="font-size: 16px; font-weight: 600; margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid var(--border);">SMTP Configuration</h2>
<form class="admin-form" action="/admin/email-settings" method="post">

<div class="form-row">
<div class="form-group">
<label for="smtp_from">From Email *</label>
<input type="email" id="smtp_from" name="smtp_from" value="<%= smtp.from || '' %>" placeholder="noreply@example.com" required>
</div>
<div class="form-group">
<label for="smtp_from_name">From Name</label>
<input type="text" id="smtp_from_name" name="smtp_from_name" value="<%= smtp.from_name || 'StatusFe' %>" placeholder="StatusFe">
</div>
</div>

<div class="form-row">
<div class="form-group">
<label for="smtp_host">SMTP Host *</label>
<input type="text" id="smtp_host" name="smtp_host" value="<%= smtp.host || '' %>" placeholder="smtp.gmail.com" required>
</div>
<div class="form-group">
<label for="smtp_port">SMTP Port</label>
<input type="number" id="smtp_port" name="smtp_port" value="<%= smtp.port || '587' %>" placeholder="587">
</div>
</div>

<div class="form-row">
<div class="form-group">
<label for="smtp_user">Username</label>
<input type="text" id="smtp_user" name="smtp_user" value="<%= smtp.user || '' %>" placeholder="user@example.com">
</div>
<div class="form-group">
<label for="smtp_pass">Password</label>
<input type="password" id="smtp_pass" name="smtp_pass" placeholder="Leave blank to keep current">
</div>
</div>

<div class="form-group checkbox-group">
<label>
<input type="checkbox" name="smtp_secure" value="1" <%= smtp.secure === 'true' ? 'checked' : '' %>>
Use SSL/TLS
</label>
</div>

<div class="form-actions">
<button type="submit" class="btn btn-primary">Save SMTP Settings</button>
</div>
</form>
</div>

<div class="card">
<h2 style="font-size: 16px; font-weight: 600; margin-bottom: 16px; padding-bottom: 12px; border-bottom: 1px solid var(--border);">Test Email</h2>
<div class="form-group">
<label for="test_to">Send test email to</label>
<input type="email" id="test_to" placeholder="test@example.com">
</div>
<div class="form-actions" style="border: none; padding: 0; margin-top: 12px;">
<button class="btn btn-primary" onclick="testEmail()">Send Test Email</button>
</div>
<div id="testResult" style="margin-top: 12px;"></div>
</div>
</div>

</main>
</div>
<script src="/js/admin.js"></script>
<script>
// Tab switching
document.querySelectorAll('.doc-tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.doc-tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.doc-tab-content').forEach(c => c.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
  });
});

function testEmail() {
  const to = document.getElementById('test_to').value;
  if (!to) { alert('Enter a test email address'); return; }
  const result = document.getElementById('testResult');
  result.innerHTML = '<p class="text-muted">Sending test email...</p>';
  fetch('/admin/email-settings/test', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ to: to })
  })
  .then(r => r.json())
  .then(data => {
    if (data.ok) {
      result.innerHTML = '<p style="color: var(--success); font-size: 14px;">Test email sent successfully!</p>';
    } else {
      result.innerHTML = '<p style="color: var(--danger); font-size: 14px;">Failed: ' + (data.error || 'Unknown error') + '</p>';
    }
  })
  .catch(err => {
    result.innerHTML = '<p style="color: var(--danger); font-size: 14px;">Error: ' + err.message + '</p>';
  });
}
</script>
</body>
</html>
