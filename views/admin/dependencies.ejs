<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> - StatusPage Admin</title>
<link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="admin-layout">
<aside class="sidebar">
<div class="sidebar-header">
<h2>StatusPage</h2>
<span class="sidebar-subtitle">Admin Panel</span>
</div>
<nav class="sidebar-nav">
<a href="/admin"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>Dashboard</a>
<a href="/admin/pages"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>Pages</a>
<a href="/admin/components"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42 1.42M18.36 5.64l1.42 1.42"/></svg>Components</a>
<a href="/admin/incidents"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>Incidents</a>
<a href="/admin/maintenance"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>Maintenance</a>
<a href="/admin/notifications"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>Notifications</a>
<a href="/admin/analytics"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>Analytics</a>
<a href="/admin/dependencies" class="active"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>Dependencies</a>
<a href="/admin/api-keys"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>API Keys</a>
<a href="/admin/docs"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>API Docs</a>
<a href="/admin/users"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>Users</a>
</nav>
<div class="sidebar-footer">
<div class="user-info">
<span class="user-name"><%= user.name %></span>
<span class="user-role"><%= user.role %></span>
</div>
<form action="/auth/logout" method="post"><button type="submit" class="btn-logout">Logout</button></form>
</div>
</aside>
<main class="admin-main">
<div class="admin-header"><h1><%= title %></h1></div>

<div class="card">
<h3>Add Dependency</h3>
<form action="/admin/dependencies" method="post">
<div class="form-row">
<div class="form-group">
<label for="component_id">Component</label>
<select id="component_id" name="component_id" required>
<option value="">Select component...</option>
<% components.forEach(c => { %>
<option value="<%= c.id %>"><%= c.name %></option>
<% }) %>
</select>
</div>
<div class="form-group">
<label for="depends_on">Depends On</label>
<select id="depends_on" name="depends_on" required>
<option value="">Select component...</option>
<% components.forEach(c => { %>
<option value="<%= c.id %>"><%= c.name %></option>
<% }) %>
</select>
</div>
</div>
<div class="form-group checkbox-group">
<label>
<input type="checkbox" id="cascade_status" name="cascade_status" checked>
Cascade status (if dependency is down, mark this component as affected)
</label>
</div>
<div class="form-actions">
<button type="submit" class="btn btn-primary">Add Dependency</button>
</div>
</form>
</div>

<% const allDeps = []; components.forEach(c => { c.dependencies.forEach(d => { allDeps.push({...d, componentName: c.component.name, dependsOnName: components.find(x=>x.component.id===d.depends_on)?.component.name}); }); }); %>

<% if (allDeps.length > 0) { %>
<div class="card" style="margin-top:20px;">
<h3>Existing Dependencies</h3>
<div class="table-container">
<table class="admin-table">
<thead>
<tr><th>Component</th><th>Depends On</th><th>Cascade</th><th>Actions</th></tr>
</thead>
<tbody>
<% allDeps.forEach(d => { %>
<tr>
<td><strong><%= d.componentName %></strong></td>
<td><%= d.dependsOnName %></td>
<td><span class="<%= d.cascade_status ? 'yes' : 'no' %>"><%= d.cascade_status ? 'Yes' : 'No' %></span></td>
<td class="actions">
<form action="/admin/dependencies/<%= d.id %>?_method=DELETE" method="post" class="delete-form">
<button type="submit" class="btn btn-sm btn-danger">Remove</button>
</form>
</td>
</tr>
<% }) %>
</tbody>
</table>
</div>
</div>
<% } else { %>
<div class="card" style="margin-top:20px;"><p class="text-muted">No dependencies configured.</p></div>
<% } %>
</main>
</div>
<button class="theme-toggle" onclick="toggleTheme()"><span id="themeIcon">🌙</span></button>
<script src="/js/admin.js"></script>
<script>
(function(){const s=localStorage.getItem('statuspage-theme');if(s==='dark'){document.body.classList.add('dark');const i=document.getElementById('themeIcon');if(i)i.textContent='☀️';}})();
function toggleTheme(){document.body.classList.toggle('dark');const i=document.getElementById('themeIcon');if(document.body.classList.contains('dark')){localStorage.setItem('statuspage-theme','dark');if(i)i.textContent='☀️';}else{localStorage.setItem('statuspage-theme','light');if(i)i.textContent='🌙';}}
</script>
</body>
</html>
