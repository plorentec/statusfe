<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> - StatusFe Admin</title>
<link rel="stylesheet" href="/css/admin.css">
<script>document.body.classList.add('dark');</script>
</head>
<body>
<div class="admin-layout">
<%- include('../partials/_sidebar'); %>
<main class="admin-main">
<div class="admin-header"><h1><%= title %></h1>
<% if (message) { %>
<div class="flash flash-<%= messageType %>"><%= message %></div>
<% } %>
</div>

<div class="card">
<h3 style="font-size:16px;font-weight:600;margin-bottom:16px;padding-bottom:12px;border-bottom:1px solid var(--border);">Add Dependency</h3>
<form action="/admin/dependencies" method="post">
<div class="form-row">
<div class="form-group">
<label for="component_id">Component</label>
<select id="component_id" name="component_id" required>
<option value="">Select component...</option>
<% components.forEach(c => { %>
<option value="<%= c.id %>"><%= c.name %></option>
<% }) %>
</select>
</div>
<div class="form-group">
<label for="depends_on">Depends On</label>
<select id="depends_on" name="depends_on" required>
<option value="">Select component...</option>
<% components.forEach(c => { %>
<option value="<%= c.id %>"><%= c.name %></option>
<% }) %>
</select>
</div>
</div>
<div class="form-group checkbox-group">
<label>
<input type="checkbox" id="cascade_status" name="cascade_status" checked>
Cascade status (if dependency is down, mark this component as affected)
</label>
</div>
<div class="form-actions">
<button type="submit" class="btn btn-primary">Add Dependency</button>
</div>
</form>
</div>

<% if (allDeps.length > 0) { %>
<div class="card" style="margin-top:20px;">
<h3 style="font-size:16px;font-weight:600;margin-bottom:16px;padding-bottom:12px;border-bottom:1px solid var(--border);">Existing Dependencies</h3>
<div class="table-container">
<table class="admin-table">
<thead>
<tr><th>Component</th><th>Depends On</th><th>Cascade</th><th>Actions</th></tr>
</thead>
<tbody>
<% allDeps.forEach(d => { %>
<tr>
<td><strong><%= d.componentName %></strong></td>
<td><%= d.dependsOnName %></td>
<td><span class="<%= d.cascade_status ? 'yes' : 'no' %>"><%= d.cascade_status ? 'Yes' : 'No' %></span></td>
<td class="actions">
<form action="/admin/dependencies/<%= d.id %>?_method=DELETE" method="post" class="delete-form">
<button type="submit" class="btn btn-sm btn-danger">Remove</button>
</form>
</td>
</tr>
<% }) %>
</tbody>
</table>
</div>
</div>
<% } else { %>
<div class="card" style="margin-top:20px;"><p class="text-muted">No dependencies configured.</p></div>
<% } %>
</main>
</div>
<script src="/js/admin.js"></script>
</body>
</html>
