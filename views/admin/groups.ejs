<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> - StatusFe Admin</title>
<link rel="stylesheet" href="/css/admin.css">
<script>document.body.classList.add('dark');</script>
</head>
<body>
<div class="admin-layout">
<%- include('../partials/_sidebar'); %>
<main class="admin-main">
<div class="admin-header">
<h1><%= title %></h1>
<% if (message) { %>
<div class="flash flash-<%= messageType %>"><%= message %></div>
<% } %>
</div>

<% if (groupMode === 'list') { %>
<div class="card-header-row">
<h2>All Groups</h2>
<a href="/admin/groups/new" class="btn btn-primary">+ New Group</a>
</div>

<div class="table-container">
<table class="admin-table">
<thead>
<tr>
<th>Name</th>
<th>Pages</th>
<th>Position</th>
<th>Components</th>
<th>Created</th>
<th>Actions</th>
</tr>
</thead>
<tbody>
<% if (groups.length === 0) { %>
<tr><td colspan="6" class="empty-cell">No groups yet. <a href="/admin/groups/new">Create your first group</a>.</td></tr>
<% } else { %>
<% groups.forEach(g => { %>
<tr>
<td><strong><%= g.name %></strong></td>
<td><% const gs = groupPageMap[g.id] || []; if (gs.length === 0) { %><span class="badge badge-success">Global</span><% } else { %>
  <% gs.forEach((p, i) => { %>
    <span class="badge badge-info"><%= p.name %><% if (i < gs.length-1) { %>, <% } %></span>
  <% }) %>
<% } %></td>
<td><%= g.position %></td>
<td><%= groupComponentCounts[g.id] || 0 %></td>
<td><%= g.created_at %></td>
<td class="actions">
<a href="/admin/groups/<%= g.id %>/edit" class="btn btn-sm">Edit</a>
<form action="/admin/groups/<%= g.id %>?_method=DELETE" method="post" class="delete-form" onsubmit="return confirm('Delete this group? Components will be unassigned.')">
<button type="submit" class="btn btn-sm btn-danger">Delete</button>
</form>
</td>
</tr>
<% }) %>
<% } %>
</tbody>
</table>
</div>
<% } %>

<% if (groupMode === 'create' || groupMode === 'edit') { %>
<div class="card">
<h3><%= groupMode === 'create' ? 'Create New Group' : 'Edit Group' %></h3>
<form action="<%= groupMode === 'create' ? '/admin/groups' : '/admin/groups/' + group.id %>" method="post">
<% if (groupMode === 'edit') { %>
<input type="hidden" name="_method" value="PUT">
<% } %>
<div class="form-group">
<label for="name">Group Name</label>
<input type="text" id="name" name="name" value="<%= group.name || '' %>" required placeholder="Infrastructure, Application, etc.">
</div>
<div class="form-group">
<label>Pages (select one or more, leave empty for global)</label>
<div class="checkbox-group" style="max-height: 200px; overflow-y: auto; border: 1px solid var(--border); border-radius: 6px; padding: 10px;">
<% pages.forEach(p => { %>
<label class="checkbox-label" style="display: block; padding: 4px 0;">
<input type="checkbox" name="page_ids" value="<%= p.id %>" <%= (selectedPageIds || []).includes(p.id) ? 'checked' : '' %>>
<%= p.name %>
</label>
<% }) %>
</div>
<small class="text-muted">Leave all unchecked for a global group (visible on all pages). Select specific pages to restrict this group.</small>
</div>
<div class="form-group">
<label for="position">Position</label>
<input type="number" id="position" name="position" value="<%= group.position || 0 %>" min="0">
</div>
<div class="form-actions">
<button type="submit" class="btn btn-primary"><%= groupMode === 'create' ? 'Create Group' : 'Save Changes' %></button>
<% if (groupMode === 'edit') { %>
<a href="/admin/groups" class="btn">Cancel</a>
<% } %>
</div>
</form>
</div>
<% } %>

</main>
</div>
<script src="/js/admin.js"></script>
<%- include("../partials/_csrf"); %>
<script>
document.addEventListener('DOMContentLoaded', function() {
  var token = document.getElementById('csrfToken').value;
  if (!token) return;
  var forms = document.querySelectorAll('form[method="post"], form[method="POST"]');
  for (var i = 0; i < forms.length; i++) {
    var hidden = forms[i].querySelector('input[name="_csrf"]');
    if (!hidden) {
      var input = document.createElement('input');
      input.type = 'hidden';
      input.name = '_csrf';
      input.value = token;
      forms[i].appendChild(input);
    }
  }
});
</script>
</body>
</html>
