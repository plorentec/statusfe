<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> - StatusFe Admin</title>
<link rel="stylesheet" href="/css/admin.css">
<style>
.chart-bar { display: flex; align-items: flex-end; gap: 2px; height: 120px; margin-top: 12px; }
.chart-bar .bar { flex: 1; background: var(--primary); border-radius: 3px 3px 0 0; min-width: 4px; transition: height 0.3s; }
.retention-bar { display: flex; align-items: center; gap: 12px; padding: 12px 16px; background: var(--white); border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 20px; flex-wrap: wrap; }
.retention-bar label { font-size: 14px; font-weight: 600; }
.retention-bar select { padding: 6px 12px; border: 1px solid var(--border); border-radius: 6px; font-size: 14px; background: var(--white); color: var(--text); }
.retention-bar .btn { font-size: 13px; }
.time-range-label { font-size: 13px; color: var(--text-muted); margin-left: auto; }
.select-bar { display: flex; align-items: center; gap: 12px; padding: 12px 16px; background: var(--white); border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 20px; flex-wrap: wrap; }
.select-bar label { font-size: 14px; font-weight: 600; }
.select-bar select { padding: 6px 12px; border: 1px solid var(--border); border-radius: 6px; font-size: 14px; background: var(--white); color: var(--text); }
.select-bar .btn { font-size: 13px; }
.chart-container { background: var(--white); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; margin-bottom: 20px; }
.chart-container canvas { max-height: 300px; }
</style>
</head>
<body>
<div class="admin-layout">
<%- include('/var/www/cachet/views/partials/_sidebar'); %>
<main class="admin-main">
<div class="admin-header"><h1><%= title %></h1>
<% if (message) { %>
<div class="flash flash-<%= messageType %>"><%= message %></div>
<% } %>
</div>

<!-- Disk Usage -->
<div class="card" style="margin-bottom:20px;">
<h2 style="font-size: 16px; font-weight: 600; margin-bottom: 16px; padding-bottom: 12px; border-bottom: 1px solid var(--border);">Disk Usage</h2>
<div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
<div style="flex:1;min-width:200px;">
<div style="display:flex;justify-content:space-between;font-size:14px;margin-bottom:6px;">
<span>Storage</span>
<span style="font-weight:600;"><%= diskInfo.dbSize ? (diskInfo.dbSize / (1024*1024)).toFixed(1) + ' MB (DB)' : diskInfo.percentage + '% used' %></span>
</div>
<div style="height:10px;background:var(--border);border-radius:5px;overflow:hidden;">
<div style="height:100%;width:<%= diskInfo.percentage || 0 %>%;background:<%= parseFloat(diskInfo.percentage) >= 90 ? '#ef4444' : parseFloat(diskInfo.percentage) >= 75 ? '#f59e0b' : '#10b981' %>;border-radius:5px;transition:width 0.5s;"></div>
</div>
<% if (diskInfo.total > 0) { %>
<div style="font-size:12px;color:var(--text-muted);margin-top:6px;"><%= (diskInfo.used / (1024*1024*1024)).toFixed(2) %> GB used of <%= (diskInfo.total / (1024*1024*1024)).toFixed(2) %> GB</div>
<% } %>
<% if (diskInfo.dbOnly) { %>
<div style="font-size:12px;color:var(--text-muted);margin-top:6px;">Database: <%= (diskInfo.dbSize / 1024).toFixed(0) %> KB</div>
<% } %>
</div>
</div>
</div>

<!-- Retention Settings -->
<div class="retention-bar">
<label for="retentionSelect">Data retention:</label>
<select id="retentionSelect" onchange="changeRetention()">
<option value="30" <%= parseInt(retention) === 30 ? 'selected' : '' %>>30 days</option>
<option value="90" <%= parseInt(retention) === 90 ? 'selected' : '' %>>3 months</option>
<option value="180" <%= parseInt(retention) === 180 ? 'selected' : '' %>>6 months</option>
<option value="365" <%= parseInt(retention) === 365 ? 'selected' : '' %>>1 year</option>
<option value="730" <%= parseInt(retention) === 730 ? 'selected' : '' %>>2 years</option>
<option value="1825" <%= parseInt(retention) === 1825 ? 'selected' : '' %>>5 years</option>
</select>
<button class="btn btn-sm btn-primary" onclick="changeRetention()">Apply</button>
<button class="btn btn-sm btn-danger" onclick="cleanupData()">Clean old data now</button>
<span class="time-range-label">Older data will be permanently deleted</span>
</div>

<!-- Selector: Page or Component -->
<div class="select-bar">
<label>View analytics for:</label>
<select id="analyticsType" onchange="toggleAnalytics()">
<option value="">— Select type —</option>
<option value="page">Page</option>
<option value="component">Component</option>
</select>
<select id="pageSelect" style="display:none;" onchange="loadAnalytics()">
<option value="">Select a page...</option>
<% pages.forEach(p => { %>
<option value="<%= p.id %>"><%= p.name %></option>
<% }) %>
</select>
<select id="compSelect" style="display:none;" onchange="loadAnalytics()">
<option value="">Select a component...</option>
<% components.forEach(c => { %>
<option value="<%= c.id %>"><%= c.name %></option>
<% }) %>
</select>
</div>

<!-- Chart area -->
<div id="chartArea" style="display:none;">
<div class="select-bar">
<label>Chart style:</label>
<select id="chartStyle" onchange="redrawChart()">
<option value="chart">Line Chart</option>
<option value="bar">Bar Chart</option>
</select>
<label style="margin-left:16px;">Time range:</label>
<select id="timeRange" onchange="loadAnalytics()">
<option value="1">Last 1 hour</option>
<option value="2">Last 2 hours</option>
<option value="4" selected>Last 4 hours</option>
<option value="8">Last 8 hours</option>
<option value="16">Last 16 hours</option>
<option value="24">Last 24 hours</option>
<option value="48">Last 48 hours</option>
<option value="168">Last 7 days</option>
<option value="720">Last 30 days</option>
</select>
<span class="time-range-label" id="chartTitle"></span>
</div>
<div class="chart-container">
<canvas id="mainChart" height="250"></canvas>
</div>
</div>

<!-- Component Uptime Overview -->
<div class="card">
<h2 style="font-size: 16px; font-weight: 600; margin-bottom: 16px; padding-bottom: 12px; border-bottom: 1px solid var(--border);">All Components Uptime Overview</h2>
<% if (componentUptime.length === 0) { %>
<p class="text-muted">No components yet.</p>
<% } else { %>
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;">
<% componentUptime.forEach(c => { %>
<div style="background:var(--bg);border-radius:var(--radius);padding:16px;text-align:center;">
<div style="font-size:14px;font-weight:600;margin-bottom:8px;"><%= c.name %></div>
<div style="font-size:32px;font-weight:700;color:<%= parseFloat(c.uptime) >= 99 ? 'var(--success)' : parseFloat(c.uptime) >= 95 ? 'var(--warning)' : 'var(--danger)' %>"><%= c.uptime %>%</div>
<div style="font-size:12px;color:var(--text-muted);margin-top:4px;">uptime (30d)</div>
<div style="height:8px;background:var(--border);border-radius:4px;overflow:hidden;margin-top:8px;">
<div style="height:100%;width:<%= c.uptime %>%;background:<%= parseFloat(c.uptime) >= 99 ? '#10b981' : parseFloat(c.uptime) >= 95 ? '#f59e0b' : '#ef4444' %>;border-radius:4px;"></div>
</div>
</div>
<% }) %>
</div>
<% } %>
</div>

<!-- Page Views Overview -->
<div class="card">
<h2 style="font-size: 16px; font-weight: 600; margin-bottom: 16px; padding-bottom: 12px; border-bottom: 1px solid var(--border);">Page Views Overview</h2>
<% if (pages.length === 0) { %>
<p class="text-muted">No pages configured.</p>
<% } else { %>
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;">
<% pages.forEach(p => { %>
<div class="metric-card">
<div class="metric-value"><%= p.totalViews || 0 %></div>
<div class="metric-label">Views — <%= p.name %></div>
</div>
<% }) %>
</div>
<% } %>
</div>
</main>
</div>
<button class="theme-toggle" onclick="toggleTheme()"><span id="themeIcon">🌙</span></button>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script src="/js/admin.js"></script>
<script>
(function(){const s=localStorage.getItem('statusfe-theme');if(s==='dark'){document.body.classList.add('dark');const i=document.getElementById('themeIcon');if(i)i.textContent='☀️';}})();
function toggleTheme(){document.body.classList.toggle('dark');const i=document.getElementById('themeIcon');if(document.body.classList.contains('dark')){localStorage.setItem('statusfe-theme','dark');if(i)i.textContent='☀️';}else{localStorage.setItem('statusfe-theme','light');if(i)i.textContent='🌙';}}

let mainChart = null;

const isDark = document.body.classList.contains('dark');
const gridColor = isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.06)';
const textColor = isDark ? '#94a3b8' : '#64748b';

function toggleAnalytics() {
  const type = document.getElementById('analyticsType').value;
  document.getElementById('pageSelect').style.display = type === 'page' ? '' : 'none';
  document.getElementById('compSelect').style.display = type === 'component' ? '' : 'none';
  document.getElementById('chartArea').style.display = 'none';
}

function loadAnalytics() {
  const type = document.getElementById('analyticsType').value;
  let targetId;
  if (type === 'page') {
    targetId = document.getElementById('pageSelect').value;
  } else if (type === 'component') {
    targetId = document.getElementById('compSelect').value;
  }
  if (!targetId) {
    document.getElementById('chartArea').style.display = 'none';
    return;
  }

  const hours = document.getElementById('timeRange').value;
  fetch('/admin/analytics-detail?id=' + encodeURIComponent(targetId) + '&type=' + type + '&hours=' + hours)
    .then(r => r.json())
    .then(data => {
      if (data.error) {
        showToast(data.error, 'error');
        return;
      }
      document.getElementById('chartArea').style.display = '';
      const h = data.hours || hours;
      let rangeLabel = '';
      if (h <= 24) rangeLabel = 'Last ' + h + ' hours';
      else if (h <= 720) rangeLabel = 'Last ' + (h / 24) + ' days';
      else rangeLabel = 'Last ' + (h / 24) + ' days';
      document.getElementById('chartTitle').textContent = data.name + ' — ' + rangeLabel;
      buildChart(data);
    })
    .catch(err => showToast('Failed to load data: ' + err.message, 'error'));
}

function buildChart(data) {
  const style = document.getElementById('chartStyle').value;
  const labels = data.labels;
  const datasets = data.datasets;

  if (mainChart) mainChart.destroy();

  mainChart = new Chart(document.getElementById('mainChart'), {
    type: style === 'chart' ? 'line' : 'bar',
    data: {
      labels: labels,
      datasets: datasets
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { labels: { color: textColor } }
      },
      scales: {
        x: { ticks: { color: textColor, maxTicksLimit: 15 }, grid: { color: gridColor } },
        y: { ticks: { color: textColor }, grid: { color: gridColor } }
      }
    }
  });
}

function redrawChart() {
  loadAnalytics();
}

function changeRetention() {
  const days = document.getElementById('retentionSelect').value;
  fetch('/admin/analytics/retention', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: 'retention_days=' + days
  }).then(() => location.reload());
}

function cleanupData() {
  if (!confirm('Delete all analytics data older than the retention period? This cannot be undone.')) return;
  fetch('/admin/analytics/cleanup', { method: 'POST' })
    .then(r => r.json())
    .then(data => {
      if (data.ok) {
        alert('Deleted ' + data.deleted + ' old records.');
        location.reload();
      }
    });
}
</script>
</body>
</html>
