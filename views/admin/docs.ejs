<!-- SETTINGS TAB -->
<div id="tab-settings" class="doc-tab-content">
<h2 class="doc-section-title">Settings <span class="doc-auth-badge">API Key required</span></h2>

<h3 class="doc-h2">GET /api/v1/settings <span class="doc-perm-badge perm-admin">[admin]</span></h3>
<div class="doc-code-block">
<button class="doc-copy-btn" onclick="copyCurl(this)">Copy</button>
<code data-curl="$ curl -H &quot;Authorization: Bearer $API_KEY&quot; BASE_URL + &quot;/api/v1/settings&quot;">$ curl -H "Authorization: Bearer $API_KEY" BASE_URL + "/api/v1/settings"</code>
</div>
</div>

<script>
const BASE_URL = window.location.origin;
let currentKey = '';

function showTab(tabName, btn) {
  document.querySelectorAll('.doc-tab-content').forEach(function(el) { el.classList.remove('active'); });
  document.querySelectorAll('.doc-tab-btn').forEach(function(el) { el.classList.remove('active'); });
  document.getElementById('tab-' + tabName).classList.add('active');
  if (btn) btn.classList.add('active');
}

function onKeyChange() {
  var sel = document.getElementById('apiKeySelect');
  var customInput = document.getElementById('customApiKey');
  if (sel.value === '__custom__') {
    customInput.style.display = 'block';
    customInput.focus();
  } else {
    customInput.style.display = 'none';
    currentKey = sel.options[sel.selectedIndex].getAttribute('data-key') || '';
    refreshDisplay();
  }
}

function initApiKey() {
  var sel = document.getElementById('apiKeySelect');
  var customInput = document.getElementById('customApiKey');
  <% if (keys && keys.length > 0) { %>
  sel.selectedIndex = 1;
  currentKey = sel.options[sel.selectedIndex].getAttribute('data-key') || '';
  refreshDisplay();
  <% } else { %>
  customInput.style.display = 'block';
  <% } %>
}

function onCustomKeyChange() {
  currentKey = document.getElementById('customApiKey').value.trim();
  refreshDisplay();
}

function maskKey(key) {
  if (!key || key.length <= 4) return '••••';
  return '••••' + key.slice(-4);
}

function refreshDisplay() {
  document.querySelectorAll('.doc-code-block code').forEach(function(el) {
    var original = el.getAttribute('data-curl') || '';
    var ta = document.createElement('textarea');
    ta.innerHTML = original;
    var decoded = ta.value;
    if (currentKey) {
      el.textContent = decoded.replace(/\$API_KEY/g, maskKey(currentKey));
    } else {
      el.textContent = decoded.replace(/\$API_KEY/g, 'YOUR_API_KEY');
    }
  });
}

function copyCurl(btn) {
  var block = btn.parentElement;
  var codeEl = block.querySelector('code');
  var original = codeEl ? codeEl.getAttribute('data-curl') || '' : '';
  var ta = document.createElement('textarea');
  ta.innerHTML = original;
  var text = ta.value;

  if (!text) {
    showToast('Nothing to copy', 'error');
    return;
  }

  if (currentKey) {
    text = text.replace(/\$API_KEY/g, currentKey);
  } else {
    text = text.replace(/\$API_KEY/g, 'YOUR_API_KEY');
  }

  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(text).then(function() {
      showToast('Copied to clipboard!', 'success');
    }).catch(function() {
      fallbackCopy(text);
    });
  } else {
    fallbackCopy(text);
  }
}

function fallbackCopy(text) {
  var textarea = document.createElement('textarea');
  textarea.value = text;
  textarea.style.position = 'fixed';
  textarea.style.opacity = '0';
  document.body.appendChild(textarea);
  textarea.select();
  try {
    document.execCommand('copy');
    showToast('Copied to clipboard!', 'success');
  } catch (e) {
    showToast('Failed to copy', 'error');
  }
  document.body.removeChild(textarea);
}

window.addEventListener('DOMContentLoaded', initApiKey);
</script>
