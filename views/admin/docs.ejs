<code data-curl="$ curl -X DELETE -H &quot;Authorization: Bearer $API_KEY&quot; BASE_URL + &quot;/api/v1/api-keys/UUID&quot;">$ curl -X DELETE -H "Authorization: Bearer $API_KEY" BASE_URL + "/api/v1/api-keys/UUID"</code>
</div>
</div>

<!-- WEBHOOKS TAB -->
<div id="tab-webhooks" class="doc-tab-content">
<h2 class="doc-section-title">Webhooks <span class="doc-auth-badge">API Key required</span></h2>

<h3 class="doc-h2">GET /api/v1/pages/:pageId/webhooks</h3>
<p class="doc-desc">List webhooks for a page</p>
<div class="doc-code-block">
<button class="doc-copy-btn" onclick="copyCurl(this)">Copy</button>
<code data-curl="$ curl -H &quot;Authorization: Bearer $API_KEY&quot; BASE_URL + &quot;/api/v1/pages/UUID/webhooks&quot;">$ curl -H "Authorization: Bearer $API_KEY" BASE_URL + "/api/v1/pages/UUID/webhooks"</code>
</div>

<h3 class="doc-h2">POST /api/v1/pages/:pageId/webhooks <span class="doc-perm-badge perm-write">[write]</span></h3>
<p class="doc-desc">Create webhook</p>
<p class="doc-params-label">Body parameters:</p>
<p class="doc-desc"><code data-curl="url">url</code> (required) \u2014 <code data-curl="events">events</code> \u2014 <code data-curl="secret">secret</code></p>
<p class="doc-desc">Events: <code data-curl="status.updated">status.updated</code>, <code data-curl="incident.created">incident.created</code>, <code data-curl="incident.updated">incident.updated</code>, <code data-curl="incident.deleted">incident.deleted</code>, <code data-curl="component.assigned">component.assigned</code></p>
<div class="doc-code-block">
<button class="doc-copy-btn" onclick="copyCurl(this)">Copy</button>
<code data-curl="$ curl -X POST -H &quot;Authorization: Bearer $API_KEY&quot; -H &quot;Content-Type: application/json&quot; -d &#39;{&quot;url&quot;:&quot;https://hooks.example.com/status&quot;,&quot;events&quot;:[&quot;status.updated&quot;,&quot;incident.created&quot;],&quot;secret&quot;:&quot;mysecret&quot;}&#39; BASE_URL + &quot;/api/v1/pages/UUID/webhooks&quot;">$ curl -X POST -H "Authorization: Bearer $API_KEY" -H "Content-Type: application/json" -d '{"url":"https://hooks.example.com/status","events":["status.updated","incident.created"],"secret":"mysecret"}' BASE_URL + "/api/v1/pages/UUID/webhooks"</code>
</div>

<h3 class="doc-h2">PUT /api/v1/webhooks/:id <span class="doc-perm-badge perm-write">[write]</span></h3>
<p class="doc-desc">Update webhook</p>
<p class="doc-params-label">Body parameters:</p>
<p class="doc-desc"><code data-curl="url">url</code> \u2014 <code data-curl="events">events</code> \u2014 <code data-curl="is_active">is_active</code> \u2014 <code data-curl="secret">secret</code></p>
<div class="doc-code-block">
<button class="doc-copy-btn" onclick="copyCurl(this)">Copy</button>
<code data-curl="$ curl -X PUT -H &quot;Authorization: Bearer $API_KEY&quot; -H &quot;Content-Type: application/json&quot; -d &#39;{&quot;is_active&quot;:0}&#39; BASE_URL + &quot;/api/v1/webhooks/UUID&quot;">$ curl -X PUT -H "Authorization: Bearer $API_KEY" -H "Content-Type: application/json" -d '{"is_active":0}' BASE_URL + "/api/v1/webhooks/UUID"</code>
</div>

