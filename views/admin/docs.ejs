<script src="/js/admin.js"></script>
<script>
const BASE_URL = 'https://cachet.plorentec.com';
let currentKey = '';

function showTab(tabName, btn) {
  document.querySelectorAll('.doc-tab-content').forEach(function(el) { el.classList.remove('active'); });
  document.querySelectorAll('.doc-tab-btn').forEach(function(el) { el.classList.remove('active'); });
  document.getElementById('tab-' + tabName).classList.add('active');
  if (btn) btn.classList.add('active');
}

function onKeyChange() {
  var sel = document.getElementById('apiKeySelect');
  var customInput = document.getElementById('customApiKey');
  if (sel.value === '__custom__') {
    customInput.style.display = 'block';
    customInput.focus();
  } else {
    customInput.style.display = 'none';
    currentKey = sel.value;
    refreshDisplay();
  }
}

function initApiKey() {
  var sel = document.getElementById('apiKeySelect');
  var customInput = document.getElementById('customApiKey');
  <% if (keys && keys.length > 0) { %>
  sel.selectedIndex = 1;
  currentKey = sel.value;
  refreshDisplay();
  <% } else { %>
  customInput.style.display = 'block';
  <% } %>
}

function onCustomKeyChange() {
  currentKey = document.getElementById('customApiKey').value.trim();
  refreshDisplay();
}

function refreshDisplay() {
  document.querySelectorAll('.doc-code-block code').forEach(function(el) {
    var original = el.getAttribute('data-curl') || '';
    var ta = document.createElement('textarea');
    ta.innerHTML = original;
    var decoded = ta.value;
    if (currentKey) {
      el.textContent = decoded.replace(/\$API_KEY/g, currentKey);
    } else {
      el.textContent = decoded;
    }
  });
}

function copyCurl(btn) {
  var block = btn.parentElement;
  var codeEl = block.querySelector('code');
  var text = codeEl ? codeEl.textContent.trim() : '';

  if (!text) {
    showToast('Nothing to copy', 'error');
    return;
  }

  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(text).then(function() {
      showToast('Copied to clipboard!', 'success');
    }).catch(function() {
      fallbackCopy(text);
    });
  } else {
    fallbackCopy(text);
  }
}

function fallbackCopy(text) {
  var textarea = document.createElement('textarea');
  textarea.value = text;
  textarea.style.position = 'fixed';
  textarea.style.opacity = '0';
  document.body.appendChild(textarea);
  textarea.select();
  try {
    document.execCommand('copy');
    showToast('Copied to clipboard!', 'success');
  } catch (e) {
    showToast('Failed to copy', 'error');
  }
  document.body.removeChild(textarea);
}

window.addEventListener('DOMContentLoaded', initApiKey);
</script>
<script>document.body.classList.add('dark');</script>
</body>
