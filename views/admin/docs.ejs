<code data-curl="$ curl -X DELETE -H &quot;Authorization: Bearer $API_KEY&quot; BASE_URL + &quot;/api/v1/webhooks/UUID&quot;">$ curl -X DELETE -H "Authorization: Bearer $API_KEY" BASE_URL + "/api/v1/webhooks/UUID"</code>
