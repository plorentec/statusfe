<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> - StatusFe Admin</title>
<link rel="stylesheet" href="/css/admin.css">
<script>document.body.classList.add('dark');</script>
<style>
.notice-btn.active { background:#6366f1 !important; color:#fff !important; }
</style>
</head>
<body>
<div class="admin-layout">
<%- include('../partials/_sidebar'); %>
<main class="admin-main">
<div class="admin-header"><h1><%= title %></h1>
<% if (message) { %><div class="flash flash-<%= messageType %>"><%= message %></div><% } %>
</div>

<div class="card">
<h3><%= pageMode === 'create' ? 'Schedule Maintenance Window' : 'Edit Maintenance Window' %></h3>
<form action="<%= pageMode === 'create' ? '/admin/maintenance' : '/admin/maintenance/' + window.id %>" method="post">
<% if (pageMode === 'edit') { %>
<input type="hidden" name="_method" value="PUT">
<% } %>
<div class="form-group">
<label for="page_id">Page</label>
<select id="page_id" name="page_id" required>
<option value="">-- Select page --</option>
<% pages.forEach(p => { %>
<option value="<%= p.id %>" <%= window.page_id === p.id ? 'selected' : '' %>><%= p.name %> (<%= p.slug %>)</option>
<% }) %>
</select>
</div>
<div class="form-group">
<label for="component_id">Component (optional - leave empty for all)</label>
<select id="component_id" name="component_id">
<option value="">All components</option>
<% components.forEach(c => { %>
<option value="<%= c.id %>" <%= window.component_id === c.id ? 'selected' : '' %>><%= c.name %> (<%= c.group_name || 'Other' %>)</option>
<% }) %>
</select>
</div>
<div class="form-group">
<label for="title">Title</label>
<input type="text" id="title" name="title" value="<%= window.title || '' %>" required placeholder="e.g. Database migration">
</div>
<div class="form-group">
<label for="description">Description</label>
<textarea id="description" name="description" rows="3"><%= window.description || '' %></textarea>
</div>
<div class="form-row">
<div class="form-group">
<label for="starts_at">Starts At</label>
<input type="datetime-local" id="starts_at" name="starts_at" value="<%= window.starts_at ? new Date(window.starts_at).toISOString().slice(0,16) : '' %>">
</div>
<div class="form-group">
<label for="ends_at">Ends At</label>
<input type="datetime-local" id="ends_at" name="ends_at" value="<%= window.ends_at ? new Date(window.ends_at).toISOString().slice(0,16) : '' %>">
</div>
</div>
<div class="form-group">
<label>Advance Notice (minutes before maintenance)</label>
<input type="hidden" id="advance_notice_minutes" name="advance_notice_minutes" value="<%= window.advance_notice_minutes || 0 %>">
<div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:4px">
<button type="button" class="btn btn-sm notice-btn" data-value="0" <%= (!window.advance_notice_minutes || window.advance_notice_minutes === 0) ? 'class="btn btn-sm notice-btn active"' : '' %>>None</button>
<button type="button" class="btn btn-sm notice-btn" data-value="10" <%= window.advance_notice_minutes === 10 ? 'class="btn btn-sm notice-btn active"' : '' %>>10 min</button>
<button type="button" class="btn btn-sm notice-btn" data-value="30" <%= window.advance_notice_minutes === 30 ? 'class="btn btn-sm notice-btn active"' : '' %>>30 min</button>
<button type="button" class="btn btn-sm notice-btn" data-value="60" <%= window.advance_notice_minutes === 60 ? 'class="btn btn-sm notice-btn active"' : '' %>>1 hour</button>
<button type="button" class="btn btn-sm notice-btn" data-value="120" <%= window.advance_notice_minutes === 120 ? 'class="btn btn-sm notice-btn active"' : '' %>>2 hours</button>
<button type="button" class="btn btn-sm notice-btn" data-value="240" <%= window.advance_notice_minutes === 240 ? 'class="btn btn-sm notice-btn active"' : '' %>>4 hours</button>
<button type="button" class="btn btn-sm notice-btn" data-value="360" <%= window.advance_notice_minutes === 360 ? 'class="btn btn-sm notice-btn active"' : '' %>>6 hours</button>
<button type="button" class="btn btn-sm notice-btn" data-value="480" <%= window.advance_notice_minutes === 480 ? 'class="btn btn-sm notice-btn active"' : '' %>>8 hours</button>
</div>
</div>
<div class="form-group">
<label>Notice Pages (where to show the advance notice)</label>
<% pages.forEach(p => { %>
<label style="display:block;margin:4px 0;cursor:pointer">
<input type="checkbox" name="notice_page_ids" value="<%= p.id %>" <%= (window.notice_pages && window.notice_pages.includes(p.id)) || (pageMode === 'create' && p.id === window.page_id) ? 'checked' : '' %>>
<%= p.name %>
</label>
<% }) %>
<small style="color:#888;margin-top:4px;display:block">Select which pages should show the advance notice. At least one page is required.</small>
</div>
<div class="form-actions">
<button type="submit" class="btn btn-primary"><%= pageMode === 'create' ? 'Schedule' : 'Save Changes' %></button>
<a href="/admin/maintenance" class="btn">Cancel</a>
</div>
</form>
</div>
</main>
</div>
<script src="/js/admin.js"></script>

<%- include("../partials/_csrf"); %>
<script>
(function() {
  var token = document.getElementById("csrfToken");
  if (token) {
    var forms = document.querySelectorAll("form[method=\"post\"]");
    for (var i = 0; i < forms.length; i++) {
      if (!forms[i].querySelector("input[name=\"_csrf\"]")) {
        var input = document.createElement("input");
        input.type = "hidden";
        input.name = "_csrf";
        input.value = token.value;
        forms[i].appendChild(input);
      }
    }
  }

  // Advance notice buttons
  document.querySelectorAll('.notice-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.notice-btn').forEach(function(b) { b.classList.remove('active'); });
      this.classList.add('active');
      document.getElementById('advance_notice_minutes').value = this.getAttribute('data-value');
    });
  });
})();
</script>
</body>
</html>
