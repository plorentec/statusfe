<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> - StatusPage Admin</title>
<link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="admin-layout">
<aside class="sidebar">
<div class="sidebar-header">
<h2>StatusPage</h2>
<span class="sidebar-subtitle">Admin Panel</span>
</div>
<nav class="sidebar-nav">
<a href="/admin"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>Dashboard</a>
<a href="/admin/pages"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>Pages</a>
<a href="/admin/components"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42 1.42M18.36 5.64l1.42 1.42"/></svg>Components</a>
<a href="/admin/incidents"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>Incidents</a>
<a href="/admin/maintenance" class="<%= title === 'Maintenance' ? 'active' : '' %>"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>Maintenance</a>
<a href="/admin/api-keys"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>API Keys</a>
<a href="/admin/docs"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>API Docs</a>
<a href="/admin/users"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>Users</a>
</nav>
<div class="sidebar-footer">
<div class="user-info">
<span class="user-name"><%= user.name %></span>
<span class="user-role"><%= user.role %></span>
</div>
<form action="/auth/logout" method="post"><button type="submit" class="btn-logout">Logout</button></form>
</div>
</aside>
<main class="admin-main">
<div class="admin-header"><h1><%= title %></h1>
<% if (message) { %><div class="flash flash-<%= messageType %>"><%= message %></div><% } %>
</div>

<div class="card">
<h3><%= pageMode === 'create' ? 'Schedule Maintenance Window' : 'Edit Maintenance Window' %></h3>
<form action="<%= pageMode === 'create' ? '/admin/maintenance' : '/admin/maintenance/' + window.id %>" method="post">
<% if (pageMode === 'edit') { %>
<input type="hidden" name="_method" value="PUT">
<% } %>
<div class="form-group">
<label for="page_id">Page</label>
<select id="page_id" name="page_id" required>
<option value="">-- Select page --</option>
<% pages.forEach(p => { %>
<option value="<%= p.id %>" <%= window.page_id === p.id ? 'selected' : '' %>><%= p.name %> (<%= p.slug %>)</option>
<% }) %>
</select>
</div>
<div class="form-group">
<label for="component_id">Component (optional - leave empty for all)</label>
<select id="component_id" name="component_id">
<option value="">All components</option>
<% components.forEach(c => { %>
<option value="<%= c.id %>" <%= window.component_id === c.id ? 'selected' : '' %>><%= c.name %> (<%= c.group_name || 'Other' %>)</option>
<% }) %>
</select>
</div>
<div class="form-group">
<label for="title">Title</label>
<input type="text" id="title" name="title" value="<%= window.title || '' %>" required placeholder="e.g. Database migration">
</div>
<div class="form-group">
<label for="description">Description</label>
<textarea id="description" name="description" rows="3"><%= window.description || '' %></textarea>
</div>
<div class="form-row">
<div class="form-group">
<label for="starts_at">Starts At</label>
<input type="datetime-local" id="starts_at" name="starts_at" value="<%= window.starts_at ? window.starts_at.replace(' ', 'T').substring(0,16) : '' %>">
</div>
<div class="form-group">
<label for="ends_at">Ends At</label>
<input type="datetime-local" id="ends_at" name="ends_at" value="<%= window.ends_at ? window.ends_at.replace(' ', 'T').substring(0,16) : '' %>">
</div>
</div>
<div class="form-actions">
<button type="submit" class="btn btn-primary"><%= pageMode === 'create' ? 'Schedule' : 'Save Changes' %></button>
<a href="/admin/maintenance" class="btn">Cancel</a>
</div>
</form>
</div>
</main>
</div>
<script src="/js/admin.js"></script>
</body>
</html>
