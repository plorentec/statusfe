<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> - StatusFe Admin</title>
<link rel="stylesheet" href="/css/admin.css">
<script>document.body.classList.add('dark');</script>
</head>
<body>
<div class="admin-layout">
<%- include('../partials/_sidebar'); %>
<main class="admin-main">
<div class="admin-header">
<h1><%= title %></h1>
<% if (message) { %>
<div class="flash flash-<%= messageType %>"><%= message %></div>
<% } %>
</div>

<% if (componentMode === 'list') { %>
<div class="card-header-row">
<h2>All Components</h2>
<a href="/admin/components/new" class="btn btn-primary">+ New Component</a>
</div>

<div class="table-container">
<table class="admin-table">
<thead>
<tr>
<th>Name</th>
<th>Group</th>
<th>Status</th>
<th>Position</th>
<th>Created</th>
<th>Actions</th>
</tr>
</thead>
<tbody>
<% if (components.length === 0) { %>
<tr><td colspan="6" class="empty-cell">No components yet. <a href="/admin/components/new">Create your first component</a>.</td></tr>
<% } else { %>
<% components.forEach(c => { %>
<tr>
<td><strong><%= c.name %></strong><br><small class="text-muted"><%= c.description || '' %></small></td>
<td><% if (c.group_id) { const g = groups.find(x => x.id === c.group_id); %><%= g ? g.name : '-' %><% } else { %><%= c.group_name || '-' %><% } %></td>
<td><span class="status-badge status-<%= c.status %>"><%= c.status %></span></td>
<td><%= c.position %></td>
<td><%= c.created_at %></td>
<td class="actions">
<a href="/admin/components/<%= c.id %>/edit" class="btn btn-sm">Edit</a>
<form action="/admin/components/<%= c.id %>/status" method="post" class="inline-status-form" style="display:inline;">
<select name="status" onchange="this.form.submit()" style="font-size:12px;padding:2px 6px;border:1px solid var(--border);border-radius:4px;">
<option value="operational" <%= c.status === 'operational' ? 'selected' : '' %>>Operational</option>
<option value="degraded_performance" <%= c.status === 'degraded_performance' ? 'selected' : '' %>>Degraded</option>
<option value="partial_outage" <%= c.status === 'partial_outage' ? 'selected' : '' %>>Partial</option>
<option value="major_outage" <%= c.status === 'major_outage' ? 'selected' : '' %>>Major</option>
<option value="under_maintenance" <%= c.status === 'under_maintenance' ? 'selected' : '' %>>Maint.</option>
</select>
</form>
<form action="/admin/components/<%= c.id %>?_method=DELETE" method="post" class="delete-form" onsubmit="return confirm('Delete this component?')">
<button type="submit" class="btn btn-sm btn-danger">Delete</button>
</form>
</td>
</tr>
<% }) %>
<% } %>
</tbody>
</table>
</div>
<% } %>

<% if (componentMode === 'create' || componentMode === 'edit') { %>
<div class="card">
<h3><%= componentMode === 'create' ? 'Create New Component' : 'Edit Component' %></h3>
<form action="<%= componentMode === 'create' ? '/admin/components' : '/admin/components/' + component.id %>" method="post">
<% if (componentMode === 'edit') { %>
<input type="hidden" name="_method" value="PUT">
<% } %>
<div class="form-group">
<label for="name">Name</label>
<input type="text" id="name" name="name" value="<%= component.name || '' %>" required>
</div>
<div class="form-row">
<div class="form-group">
<label for="group_id">Group</label>
<select id="group_id" name="group_id">
<option value="">No group</option>
<% if (groups) { groups.forEach(g => { %>
<option value="<%= g.id %>" <%= component.group_id === g.id ? 'selected' : '' %>><%= g.name %><% if (g.page_id) { %> — <%= pages.find(p=>p.id===g.page_id)?.name || 'Global' %><% } %></option>
<% }); } %>
</select>
</div>
<div class="form-group">
<label for="group_name">Group Name (legacy)</label>
<input type="text" id="group_name" name="group_name" value="<%= component.group_name || '' %>" placeholder="Infrastructure">
<small class="text-muted">Or use the group selector above.</small>
</div>
<div class="form-group">
<label for="position">Position</label>
<input type="number" id="position" name="position" value="<%= component.position || 0 %>" min="0">
</div>
</div>
<div class="form-group">
<label for="description">Description</label>
<textarea id="description" name="description" rows="2"><%= component.description || '' %></textarea>
</div>
<div class="form-group">
<label for="status">Status</label>
<select id="status" name="status">
<option value="operational" <%= component.status === 'operational' ? 'selected' : '' %>>Operational</option>
<option value="degraded_performance" <%= component.status === 'degraded_performance' ? 'selected' : '' %>>Degraded Performance</option>
<option value="partial_outage" <%= component.status === 'partial_outage' ? 'selected' : '' %>>Partial Outage</option>
<option value="major_outage" <%= component.status === 'major_outage' ? 'selected' : '' %>>Major Outage</option>
<option value="under_maintenance" <%= component.status === 'under_maintenance' ? 'selected' : '' %>>Under Maintenance</option>
</select>
</div>
<div class="form-actions">
<button type="submit" class="btn btn-primary"><%= componentMode === 'create' ? 'Create Component' : 'Save Changes' %></button>
<% if (componentMode === 'edit') { %>
<a href="/admin/components" class="btn">Cancel</a>
<% } %>
</div>
</form>
</div>
<% } %>

</main>
</div>
<script src="/js/admin.js"></script>

</body>
</html>
