<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> - StatusFe Admin</title>
<link rel="stylesheet" href="/css/admin.css">
<script>document.body.classList.add('dark');</script>
</head>
<body>
<div class="admin-layout">
<%- include('../partials/_sidebar'); %>
<main class="admin-main">
<div class="admin-header">
<h1><%= title %></h1>
<% if (message) { %>
<div class="flash flash-<%= messageType %>"><%= message %></div>
<% } %>
</div>

<% if (pageMode === 'list') { %>
<div class="card-header-row">
<h2>All Pages</h2>
<a href="/admin/pages/new" class="btn btn-primary">+ New Page</a>
</div>

<div class="table-container">
<table class="admin-table">
<thead>
<tr>
<th>Name</th>
<th>Slug</th>
<th>Template</th>
<th>Status</th>
<th>Public</th>
<th>Created</th>
<th>Actions</th>
</tr>
</thead>
<tbody>
<% if (pages.length === 0) { %>
<tr><td colspan="7" class="empty-cell">No pages yet. <a href="/admin/pages/new">Create your first page</a>.</td></tr>
<% } else { %>
<% pages.forEach(p => { %>
<tr>
<td><strong><%= p.name %></strong></td>
<td><code><%= p.slug %></code> <a href="/status/<%= p.slug %>" target="_blank" class="btn btn-sm btn-visit" title="Visit page">↗</a></td>
<td><span class="template-badge template-<%= p.template || 'default' %>"><%= p.template === 'grid' ? 'Grid' : p.template === 'dark' ? 'Dark' : 'Default' %></span></td>
<td><span class="status-badge status-<%= p.status %>"><%= p.status %></span></td>
<td><span class="<%= p.is_public ? 'yes' : 'no' %>"><%= p.is_public ? 'Yes' : 'No' %></span></td>
<td><%= p.created_at %></td>
<td class="actions">
<a href="/admin/pages/<%= p.id %>/edit" class="btn btn-sm">Edit</a>
<form action="/admin/pages/<%= p.id %>?_method=DELETE" method="post" class="delete-form" onsubmit="return confirm('Delete this page?')">
<button type="submit" class="btn btn-sm btn-danger">Delete</button>
</form>
</td>
</tr>
<% }) %>
<% } %>
</tbody>
</table>
</div>
<% } %>

<% if (pageMode === 'create' || pageMode === 'edit') { %>
<div class="card">
<h3><%= pageMode === 'create' ? 'Create New Page' : 'Edit Page' %></h3>
<form action="<%= pageMode === 'create' ? '/admin/pages' : '/admin/pages/' + page.id %>" method="post">
<% if (pageMode === 'edit') { %>
<input type="hidden" name="_method" value="PUT">
<% } %>
<div class="form-group">
<label for="name">Name</label>
<input type="text" id="name" name="name" value="<%= page.name || '' %>" required placeholder="My Service Status">
</div>
<div class="form-group">
<label for="slug">Slug</label>
<input type="text" id="slug" name="slug" value="<%= page.slug || '' %>" required placeholder="my-service-status">
<small class="text-muted">Auto-generated from name, or edit manually. Only lowercase letters, numbers, and hyphens</small>
</div>
<div class="form-group">
<label for="description">Description</label>
<textarea id="description" name="description" rows="2"><%= page.description || '' %></textarea>
</div>
<div class="form-group">
<label for="status">Status</label>
<select id="status" name="status">
<option value="operational" <%= page.status === 'operational' ? 'selected' : '' %>>Operational</option>
<option value="degraded_performance" <%= page.status === 'degraded_performance' ? 'selected' : '' %>>Degraded Performance</option>
<option value="partial_outage" <%= page.status === 'partial_outage' ? 'selected' : '' %>>Partial Outage</option>
<option value="major_outage" <%= page.status === 'major_outage' ? 'selected' : '' %>>Major Outage</option>
<option value="under_maintenance" <%= page.status === 'under_maintenance' ? 'selected' : '' %>>Under Maintenance</option>
</select>
</div>
<div class="form-group">
<label>Template</label>
<div class="template-preview-grid">
<% ['default', 'grid', 'dark'].forEach(t => { %>
<label class="template-option <%= (pageMode === 'edit' && page.template === t) || (pageMode === 'create' && t === 'default') ? 'selected' : '' %>">
<input type="radio" name="template" value="<%= t %>" <%= (pageMode === 'edit' && page.template === t) || (pageMode === 'create' && t === 'default') ? 'checked' : '' %> onchange="updateTemplateSelection(this)">
<div class="template-card">
<div class="template-card-header">
<span class="template-card-name"><%= t === 'default' ? 'Default' : t === 'grid' ? 'Grid' : 'Dark' %></span>
</div>
<div class="template-card-preview">
<% if (t === 'default') { %>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 280 200">
<rect width="280" height="200" fill="#ffffff" rx="8"/>
<rect x="20" y="16" width="100" height="16" rx="8" fill="#dcffe4"/>
<text x="24" y="28" font-size="8" fill="#065f46" font-family="sans-serif">System Status</text>
<line x1="20" y1="44" x2="260" y2="44" stroke="#f0f0f0" stroke-width="1"/>
<rect x="20" y="54" width="16" height="16" rx="8" fill="#10b981"/>
<rect x="44" y="56" width="80" height="8" rx="4" fill="#e2e8f0"/>
<rect x="230" y="54" width="30" height="12" rx="6" fill="#dcffe4"/>
<line x1="20" y1="80" x2="260" y2="80" stroke="#f0f0f0" stroke-width="1"/>
<rect x="20" y="88" width="16" height="16" rx="8" fill="#10b981"/>
<rect x="44" y="90" width="100" height="8" rx="4" fill="#e2e8f0"/>
<rect x="230" y="88" width="30" height="12" rx="6" fill="#dcffe4"/>
<line x1="20" y1="116" x2="260" y2="116" stroke="#f0f0f0" stroke-width="1"/>
<rect x="20" y="124" width="16" height="16" rx="8" fill="#f59e0b"/>
<rect x="44" y="126" width="70" height="8" rx="4" fill="#e2e8f0"/>
<rect x="230" y="124" width="30" height="12" rx="6" fill="#fef3c7"/>
<line x1="20" y1="152" x2="260" y2="152" stroke="#f0f0f0" stroke-width="1"/>
<rect x="20" y="160" width="16" height="16" rx="8" fill="#10b981"/>
<rect x="44" y="162" width="90" height="8" rx="4" fill="#e2e8f0"/>
<rect x="230" y="160" width="30" height="12" rx="6" fill="#dcffe4"/>
</svg>
<% } else if (t === 'grid') { %>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 280 200">
<rect width="280" height="200" fill="#f0f2f5" rx="8"/>
<rect x="0" y="0" width="280" height="36" fill="#1a1a2e"/>
<rect x="20" y="12" width="80" height="12" rx="6" fill="#ffffff" opacity="0.9"/>
<rect x="20" y="48" width="124" height="48" rx="10" fill="#ffffff" stroke="#e2e6ea" stroke-width="1"/>
<rect x="20" y="48" width="124" height="4" fill="#6366f1"/>
<rect x="28" y="60" width="60" height="6" rx="3" fill="#1a1a2e"/>
<rect x="28" y="72" width="80" height="5" rx="2.5" fill="#e2e8f0"/>
<rect x="156" y="48" width="104" height="48" rx="10" fill="#ffffff" stroke="#e2e6ea" stroke-width="1"/>
<rect x="156" y="48" width="104" height="4" fill="#10b981"/>
<rect x="164" y="60" width="50" height="6" rx="3" fill="#1a1a2e"/>
<rect x="164" y="72" width="70" height="5" rx="2.5" fill="#e2e8f0"/>
<rect x="20" y="104" width="124" height="48" rx="10" fill="#ffffff" stroke="#e2e6ea" stroke-width="1"/>
<rect x="20" y="104" width="124" height="4" fill="#f59e0b"/>
<rect x="28" y="116" width="70" height="6" rx="3" fill="#1a1a2e"/>
<rect x="28" y="128" width="60" height="5" rx="2.5" fill="#e2e8f0"/>
<rect x="156" y="104" width="104" height="48" rx="10" fill="#ffffff" stroke="#e2e6ea" stroke-width="1"/>
<rect x="156" y="104" width="104" height="4" fill="#10b981"/>
<rect x="164" y="116" width="55" height="6" rx="3" fill="#1a1a2e"/>
<rect x="164" y="128" width="75" height="5" rx="2.5" fill="#e2e8f0"/>
<rect x="20" y="164" width="240" height="24" rx="10" fill="#ffffff" stroke="#e2e6ea" stroke-width="1"/>
<rect x="28" y="172" width="60" height="8" rx="4" fill="#e2e8f0"/>
</svg>
<% } else { %>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 280 200">
<rect width="280" height="200" fill="#0a0a0f" rx="8"/>
<rect x="0" y="0" width="280" height="32" fill="#12121a"/>
<rect x="20" y="10" width="70" height="12" rx="6" fill="#ffffff" opacity="0.8"/>
<rect x="20" y="40" width="240" height="8" rx="4" fill="rgba(34,197,94,0.3)"/>
<rect x="20" y="56" width="240" height="28" rx="8" fill="#12121a" stroke="#1e1e2e" stroke-width="1"/>
<circle cx="32" cy="70" r="5" fill="#22c55e"/>
<rect x="44" y="62" width="90" height="6" rx="3" fill="rgba(255,255,255,0.2)"/>
<rect x="20" y="92" width="240" height="28" rx="8" fill="#12121a" stroke="#1e1e2e" stroke-width="1"/>
<circle cx="32" cy="106" r="5" fill="#22c55e"/>
<rect x="44" y="102" width="110" height="6" rx="3" fill="rgba(255,255,255,0.2)"/>
<rect x="20" y="128" width="240" height="28" rx="8" fill="#12121a" stroke="#1e1e2e" stroke-width="1"/>
<circle cx="32" cy="142" r="5" fill="#eab308"/>
<rect x="44" y="138" width="70" height="6" rx="3" fill="rgba(255,255,255,0.2)"/>
<rect x="20" y="164" width="240" height="28" rx="8" fill="#12121a" stroke="#1e1e2e" stroke-width="1"/>
<circle cx="32" cy="178" r="5" fill="#22c55e"/>
<rect x="44" y="174" width="80" height="6" rx="3" fill="rgba(255,255,255,0.2)"/>
</svg>
<% } %>
</div>
</div>
</label>
<% }) %>
</div>
</div>
<div class="form-group checkbox-group">
<label>
<input type="checkbox" id="is_public" name="is_public" <%= page.is_public ? 'checked' : '' %>>
Make page public
</label>
</div>
<div class="form-group">
<label>Components</label>
<% if (components && components.length > 0) { %>
<div class="component-checkboxes">
<% components.forEach(c => { %>
<label class="component-checkbox">
<input type="checkbox" name="component_ids" value="<%= c.id %>" <%= (assignedComponentIds || []).includes(c.id) ? 'checked' : '' %>>
<%= c.name %> <small class="text-muted">(<%= c.group_name || 'Other' %>)</small>
</label>
<% }) %>
</div>
<% } else { %>
<small class="text-muted">No components created yet. <a href="/admin/components/new">Create components first</a>.</small>
<% } %>
</div>
<div class="form-actions">
<button type="submit" class="btn btn-primary"><%= pageMode === 'create' ? 'Create Page' : 'Save Changes' %></button>
<% if (pageMode === 'edit') { %>
<a href="/admin/pages" class="btn">Cancel</a>
<% } %>
</div>
</form>
</div>
<% } %>

</main>
</div>
<script src="/js/admin.js"></script>
<script>
const nameInput = document.getElementById('name');
const slugInput = document.getElementById('slug');

if (nameInput && slugInput && (!slugInput.value || nameInput.value)) {
  if (nameInput.value && !slugInput.value) {
    slugInput.value = generateSlug(nameInput.value);
  }
}

nameInput.addEventListener('input', function() {
  if (!this.dataset.manual) {
    slugInput.value = generateSlug(this.value);
  }
});

slugInput.addEventListener('blur', function() {
  this.dataset.manual = 'true';
});

slugInput.addEventListener('focus', function() {
  delete this.dataset.manual;
});

function generateSlug(name) {
  return name
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');
}

function updateTemplateSelection(radio) {
  document.querySelectorAll('.template-option').forEach(el => {
    el.classList.remove('selected');
  });
  radio.closest('.template-option').classList.add('selected');
}
</script>

</body>
</html>
